# NameSilo Intelligence environment variables

# NameSilo public API key (from API Manager in your NameSilo account)
NAMESILO_API_KEY=

# Set to true to use sandbox.namesilo.com
NAMESILO_API_SANDBOX=false

# Internal marketplace API — must be a full HTTPS URL, NOT your API key
# Example: https://marketplace-api.namesilo.com/v1
NAMESILO_MARKETPLACE_API_URL=

# Bearer token for the internal marketplace API (optional)
NAMESILO_MARKETPLACE_API_KEY=

# Public site URL for SEO (canonical, sitemap, OG)
NEXT_PUBLIC_SITE_URL=https://intel.namesilo.com
